{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=autenticacionPomelo;Trusted_Connection=True;TrustServerCertificate=true;"
  },
  "Swagger": {
    "Enabled": true
  },
  "Http": {
    "UseHttpsRedirection": false
  },

  "SaltSettings": {
    "SaltSize": 32,
    "HashSize": 64
  },

  "Argon2Settings": {
    "DegreeOfParallelism": 8,
    "MemorySize": 8192,
    "Iterations": 40
  },

  "JwtSettings": {
    "TokenExpirationMinutes": 18000,
    "key": "dev-super-secret-key-change-me"
  },

  "RefreshTokenSettings": {
    "Lenght": 64,
    "LifeTimeInMinutes": 240,
    "IdleTimeoutMinutes": 30 //tras X min sin usar el refresh token, expira
  },

  "LockoutSettings": {
    "MaxFailedAccessAttempts": 5,
    "LockoutDurationMinutes": 15
  },
  "BootstrapAdmin": {
    "Enabled": true,
    "Email": "admin@pomelo.test",
    "Password": "Admin123!",
    "FirstName": "Admin",
    "LastName": "Pomelo",
    "Dni": "12345678"
  }
}
